# ============================================
# SUPABASE
# supabase.com → Project → Settings → API
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# STRIPE (Sandbox/Test)
# stripe.com → Developers → API keys
# ============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs — Product catalogue → Price ID
STRIPE_PRICE_ESSENTIAL=price_xxx
STRIPE_PRICE_PROFESSIONAL=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx
STRIPE_PRICE_ADDITIONAL_STAFF=price_xxx

# Staff limits per plan (included free)
STAFF_LIMIT_ESSENTIAL=3
STAFF_LIMIT_PROFESSIONAL=12
STAFF_LIMIT_ENTERPRISE=999

# ============================================
# APP
# ============================================
NEXT_PUBLIC_BASE_URL=https://www.sunshines88.com
NEXT_PUBLIC_SITE_URL=https://www.sunshines88.com
NEXT_PUBLIC_APP_NAME=Sunshine Booking System

# ============================================
# EMAIL (Resend)
# resend.com → API Keys
# ============================================
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@sunshines88.com
RESEND_FROM_NAME=Sunshine Booking
AUTH_FROM_EMAIL=Sunshine System <noreply@sunshines88.com>

# ============================================
# SUNSHINE ADMIN (/dashboard)
# ============================================
SUNSHINE_ADMIN_EMAIL=admin@sunshines88.com
